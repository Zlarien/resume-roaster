PORT=7860

# Provider: openai | groq | huggingface
LLM_PROVIDER=groq

# OpenAI settings (if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Groq settings (if LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Hugging Face Inference API settings (if LLM_PROVIDER=huggingface)
HF_API_KEY=
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Optional safety controls
MAX_FILE_SIZE_MB=6

# CORS allowlist (use your domain in production)
CORS_ORIGIN=*
